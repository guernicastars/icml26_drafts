\@writefile{lot}{\contentsline {table}{\numberline {1}{\ignorespaces Global convergence rates (\% of seeds reaching the Pareto-optimal Nash) over 100 seeds, 1\,000 episodes each. Both REINFORCE and vanilla \textsc  {Meta-MAPG}{} score 0\% in every setting, confirming the \emph  {local} nature of Theorem\nobreakspace  {}3(i): agents initialised in the risk-dominant basin converge there, as the theorem only guarantees convergence within a neighbourhood of a stable Nash. \relax }}{3}{table.caption.2}\protected@file@percent }
\providecommand*\caption@xref[2]{\@setref\relax\@undefined{#1}}
\newlabel{tab:matrix_convergence}{{1}{3}{Global convergence rates (\% of seeds reaching the Pareto-optimal Nash) over 100 seeds, 1\,000 episodes each. Both REINFORCE and vanilla \MAPG {} score 0\% in every setting, confirming the \emph {local} nature of Theorem~3(i): agents initialised in the risk-dominant basin converge there, as the theorem only guarantees convergence within a neighbourhood of a stable Nash. \relax }{table.caption.2}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces Convergence rates to the Pareto-optimal Nash equilibrium. Only \textsc  {Meta-MAPG+R}{} achieves non-zero global convergence. The gap between IPD (24\%) and Stag Hunt (97\%) reflects the deeper basin of attraction around $(D,D)$: escaping it requires more restarts and more episodes per restart. \relax }}{3}{figure.caption.3}\protected@file@percent }
\newlabel{fig:algo_comparison}{{1}{3}{Convergence rates to the Pareto-optimal Nash equilibrium. Only \OUR {} achieves non-zero global convergence. The gap between IPD (24\%) and Stag Hunt (97\%) reflects the deeper basin of attraction around $(D,D)$: escaping it requires more restarts and more episodes per restart. \relax }{figure.caption.3}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {2.3}Threshold Ablation}{3}{subsection.2.3}\protected@file@percent }
\newlabel{sec:threshold_ablation}{{2.3}{3}{Threshold Ablation}{subsection.2.3}{}}
\citation{Giannou2022}
\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces Convergence rate vs.\ restart threshold $\tau $ in Stag Hunt (100 seeds, sampling-based updates). $\tau =0$: restarts effectively disabled. $\tau =1.5$: below the mean exploration reward ($\approx 2$--$3$), so restarts rarely fire. $\tau =2.8$ (\textbf  {best}): falls in the zone where agents stuck in mixed-strategy play trigger restarts, but agents approaching $(S,S)$ do not. $\tau =5.0$: above $(S,S)$ payoff of\nobreakspace  {}5, causing constant restarts that prevent learning. \relax }}{4}{figure.caption.4}\protected@file@percent }
\newlabel{fig:threshold}{{2}{4}{Convergence rate vs.\ restart threshold $\tau $ in Stag Hunt (100 seeds, sampling-based updates). $\tau =0$: restarts effectively disabled. $\tau =1.5$: below the mean exploration reward ($\approx 2$--$3$), so restarts rarely fire. $\tau =2.8$ (\textbf {best}): falls in the zone where agents stuck in mixed-strategy play trigger restarts, but agents approaching $(S,S)$ do not. $\tau =5.0$: above $(S,S)$ payoff of~5, causing constant restarts that prevent learning. \relax }{figure.caption.4}{}}
\@writefile{toc}{\contentsline {section}{\numberline {3}Experiment II: MAMuJoCo HalfCheetah}{4}{section.3}\protected@file@percent }
