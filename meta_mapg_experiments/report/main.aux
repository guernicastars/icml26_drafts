\@writefile{lot}{\contentsline {table}{\numberline {2}{\ignorespaces Mean reward over the final 50 episodes. All three restart configurations fail to outperform the baseline. Condition\nobreakspace  {}(b) uses a threshold far above achievable reward, triggering 27--32 restarts. Condition\nobreakspace  {}(c) uses a Giannou-faithful sliding window, but the early exploration phase ($\approx \!-350$) is indistinguishable from the sub-optimal Nash ($\approx \!-350$), so the detector fires on all seeds during the first 500 episodes, preventing gait formation. \relax }}{4}{table.caption.5}\protected@file@percent }
\newlabel{tab:mujoco}{{2}{4}{Mean reward over the final 50 episodes. All three restart configurations fail to outperform the baseline. Condition~(b) uses a threshold far above achievable reward, triggering 27--32 restarts. Condition~(c) uses a Giannou-faithful sliding window, but the early exploration phase ($\approx \!-350$) is indistinguishable from the sub-optimal Nash ($\approx \!-350$), so the detector fires on all seeds during the first 500 episodes, preventing gait formation. \relax }{table.caption.5}{}}
\citation{Giannou2022}
\citation{Lin2022}
\citation{Meta2024}
\citation{OpenAssistant2023}
\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces All four seeds: 100-episode rolling mean. The \textbf  {baseline} (blue solid) reaches positive reward on 3/4 seeds. \textsc  {Meta-MAPG+R}{} with $\tau =1500$ (red solid) over-restarts catastrophically. The Giannou-faithful sliding-window variant (gold dashed, $\tau =-280$) also over-restarts because the exploration phase reward and the sub-optimal Nash have indistinguishable magnitudes. \relax }}{5}{figure.caption.6}\protected@file@percent }
\newlabel{fig:mujoco_all}{{3}{5}{All four seeds: 100-episode rolling mean. The \textbf {baseline} (blue solid) reaches positive reward on 3/4 seeds. \OUR {} with $\tau =1500$ (red solid) over-restarts catastrophically. The Giannou-faithful sliding-window variant (gold dashed, $\tau =-280$) also over-restarts because the exploration phase reward and the sub-optimal Nash have indistinguishable magnitudes. \relax }{figure.caption.6}{}}
