\citation{Giannou2022}
\@writefile{toc}{\contentsline {subsection}{\numberline {4.2}Results: Threshold Sensitivity Replicated at Scale}{6}{subsection.4.2}\protected@file@percent }
\@writefile{lot}{\contentsline {table}{\numberline {3}{\ignorespaces Global mean truth scores over TruthfulQA debate rounds. The baseline slowly learns a relatively truthful strategy, while the restart condition ($\tau =0.5$) clearly exhibits the uncalibrated ``over-restarting'' regime, wiping progress before it can stick. \relax }}{6}{table.caption.7}\protected@file@percent }
\newlabel{tab:llm_results}{{3}{6}{Global mean truth scores over TruthfulQA debate rounds. The baseline slowly learns a relatively truthful strategy, while the restart condition ($\tau =0.5$) clearly exhibits the uncalibrated ``over-restarting'' regime, wiping progress before it can stick. \relax }{table.caption.7}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces DeBERTa truth score over time. The baseline (blue squares) naturally meanders but establishes a positive trajectory, ending with a mean score of $\approx +1.0$ in the final 100 rounds. In contrast, with $\tau =0.5$ set above the initial exploration regime, the global restart mechanism triggers \textbf  {148 times} (roughly once every 5.5 rounds). This frequent wiping of the LoRA adapters traps the performance near $-4.0$. \relax }}{6}{figure.caption.8}\protected@file@percent }
\newlabel{fig:llm_progression}{{4}{6}{DeBERTa truth score over time. The baseline (blue squares) naturally meanders but establishes a positive trajectory, ending with a mean score of $\approx +1.0$ in the final 100 rounds. In contrast, with $\tau =0.5$ set above the initial exploration regime, the global restart mechanism triggers \textbf {148 times} (roughly once every 5.5 rounds). This frequent wiping of the LoRA adapters traps the performance near $-4.0$. \relax }{figure.caption.8}{}}
