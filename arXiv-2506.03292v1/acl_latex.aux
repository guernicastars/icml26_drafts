\@writefile{lof}{\contentsline {figure}{\numberline {6}{\ignorespaces Pairwise cosine similarities of steering vectors, averaged within each steering prompt, for our two \textsc  {HyperSteer}{} variants. (\subref  {fig:sim-ca-concept10}) \textbf  {Cross-attention}: strong on-diagonal (same steering prompt) alignment with some off-diagonal variance due to prompt conditioning. (\subref  {fig:sim-nc-concept10}) \textbf  {No-context}: generally weaker off-diagonal alignment. We hypothesize that cross-attention’s higher off-diagonal similarity arises from shared semantic and linguistic structure across prompts even when steering prompt labels differ.\relax }}{10}{figure.caption.38}\protected@file@percent }
\newlabel{fig:combined}{{6}{10}{Pairwise cosine similarities of steering vectors, averaged within each steering prompt, for our two \methodname {} variants. (\subref {fig:sim-ca-concept10}) \textbf {Cross-attention}: strong on-diagonal (same steering prompt) alignment with some off-diagonal variance due to prompt conditioning. (\subref {fig:sim-nc-concept10}) \textbf {No-context}: generally weaker off-diagonal alignment. We hypothesize that cross-attention’s higher off-diagonal similarity arises from shared semantic and linguistic structure across prompts even when steering prompt labels differ.\relax }{figure.caption.38}{}}
